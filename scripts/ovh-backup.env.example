# Config sync backups cross-cloud → OVH Object Storage (HDS)
# Copier vers scripts/ovh-backup.env sur le VPS (chmod 600, owner = user du cron de backup).
# backup-postgres.sh source ce fichier puis déclenche sync-backups-to-ovh.sh.
# Les valeurs peuvent réutiliser l'utilisateur S3 OVH existant (S3_* du .env API) ;
# créer un bucket DÉDIÉ aux backups (distinct du bucket documents patients).
OVH_S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
OVH_S3_ACCESS_KEY_ID=<ovh-s3-access-key>
OVH_S3_SECRET_ACCESS_KEY=<ovh-s3-secret-key>
OVH_S3_REGION=gra
OVH_S3_BUCKET=psyscale-backups-prod
