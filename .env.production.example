# ─────────────────────────────────────────────────────────────────
# PsyScale — Variables d'environnement PRODUCTION
# Copier en .env.production et remplir toutes les valeurs
# JAMAIS committer ce fichier avec les vraies valeurs
# ─────────────────────────────────────────────────────────────────

# ─── Base de données ─────────────────────────────────────────────
DATABASE_URL=postgresql://psyscale:PASSWORD@RDS_ENDPOINT:5432/psyscale?schema=public&sslmode=require

# ─── Redis (BullMQ queues) ────────────────────────────────────────
REDIS_URL=rediss://ELASTICACHE_ENDPOINT:6379

# ─── Chiffrement HDS (AES-256-GCM) ──────────────────────────────
# Générer : openssl rand -hex 32
ENCRYPTION_KEY=GENERATE_32_BYTES_HEX

# ─── JWT ─────────────────────────────────────────────────────────
# Générer : openssl rand -base64 48
JWT_SECRET=GENERATE_48_BYTES_BASE64
PATIENT_JWT_SECRET=GENERATE_DIFFERENT_48_BYTES_BASE64

# ─── Keycloak (OVH HDS) ──────────────────────────────────────────
KEYCLOAK_URL=https://auth.psylib.eu
KEYCLOAK_REALM=psyscale
KEYCLOAK_CLIENT_ID=psyscale-api
KEYCLOAK_CLIENT_SECRET=KEYCLOAK_SECRET_FROM_CONSOLE
KEYCLOAK_ADMIN_CLIENT_ID=psyscale-admin
KEYCLOAK_ADMIN_SECRET=KEYCLOAK_ADMIN_SECRET

# ─── Stripe ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_XXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXX
# Price IDs depuis Stripe Dashboard
STRIPE_PRICE_STARTER_MONTHLY=price_XXXXX
STRIPE_PRICE_PRO_MONTHLY=price_XXXXX
STRIPE_PRICE_CLINIC_MONTHLY=price_XXXXX

# ─── IA ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXX
# Optionnel fallback
# OPENAI_API_KEY=sk-XXXXX

# ─── Emails (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_XXXXX
EMAIL_FROM=noreply@psylib.eu

# ─── SMS (OVH) ──────────────────────────────────────────────────
# Créer sur https://eu.api.ovh.com/createApp/
OVH_SMS_APP_KEY=xxx
OVH_SMS_APP_SECRET=xxx
OVH_SMS_CONSUMER_KEY=xxx
OVH_SMS_SERVICE_NAME=sms-xxxx
OVH_SMS_SENDER=PsyLib

# ─── URLs ────────────────────────────────────────────────────────
WEB_URL=https://app.psylib.eu
API_URL=https://api.psylib.eu

# ─── AWS ─────────────────────────────────────────────────────────
AWS_REGION=eu-west-3
AWS_S3_PATIENTS_BUCKET=psyscale-patients-docs-prod
AWS_S3_COURSES_BUCKET=psyscale-courses-videos-prod

# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Next.js (Web) ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.psylib.eu
NEXT_PUBLIC_WS_URL=wss://api.psylib.eu
NEXTAUTH_URL=https://app.psylib.eu
NEXTAUTH_SECRET=GENERATE_32_BYTES_BASE64
