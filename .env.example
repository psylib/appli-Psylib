# =============================================================================
# PsyScale — Variables d'environnement
# Copier en .env et remplir les valeurs
# ATTENTION : Ne jamais committer .env — données de santé (HDS)
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://psyscale:psyscale@localhost:5432/psyscale

# -----------------------------------------------------------------------------
# Redis (BullMQ queues)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Keycloak (Auth — OVH HDS en production)
# -----------------------------------------------------------------------------
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=psyscale
KEYCLOAK_CLIENT_ID=psyscale-app
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_ADMIN_CLIENT_ID=psyscale-admin
KEYCLOAK_ADMIN_SECRET=change-me

# -----------------------------------------------------------------------------
# Chiffrement applicatif HDS (AES-256-GCM)
# Générer : openssl rand -hex 32
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=<32-bytes-hex-random>
# JWT secret pour les patients (indépendant de Keycloak)
# Générer : openssl rand -base64 48
PATIENT_JWT_SECRET=<random-secret-min-32-chars>
# URL du frontend web (pour les liens d'invitation)
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Next.js Auth (next-auth v5)
# Générer : openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Stripe (Phase 3 — Monétisation)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Plans Stripe (Price IDs depuis Stripe Dashboard)
STRIPE_PRICE_ID_STARTER=price_1TEa2GQ4dPA7CL6XnufX05DU
STRIPE_PRICE_ID_PRO=price_1TEa2JQ4dPA7CL6XaYJKmlcc
STRIPE_PRICE_ID_CLINIC=price_1TEa2LQ4dPA7CL6XHsE8SrFR

# -----------------------------------------------------------------------------
# IA (Phase 2)
# CRITIQUE : Ne jamais envoyer données patients sans consentement explicite
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Email (Phase 4 — Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=noreply@psylib.eu

# -----------------------------------------------------------------------------
# Monitoring (sans données patients)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog (analytics psy uniquement — jamais patients)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# -----------------------------------------------------------------------------
# AWS S3 (Phase 2 — Stockage fichiers HDS)
# -----------------------------------------------------------------------------
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_PATIENTS=
AWS_S3_BUCKET_COURSES=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
