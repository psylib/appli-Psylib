// =============================================================================
// PsyScale — Prisma Schema
// PostgreSQL — HDS conforme
// Champs sensibles marqués // ENCRYPTED — chiffrés AES-256-GCM via EncryptionService
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  psychologist
  patient
  admin
}

enum SubscriptionPlan {
  free
  starter
  pro
  clinic
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

enum SessionType {
  individual
  group
  online
}

enum SessionPaymentStatus {
  pending
  paid
  free
}

enum PatientStatus {
  active
  inactive
  archived
}

enum AppointmentStatus {
  scheduled
  confirmed
  cancelled
  completed
  no_show
}

enum ExerciseStatus {
  assigned
  in_progress
  completed
  skipped
}

enum InvitationStatus {
  pending
  accepted
  expired
}

enum PaymentType {
  session
  course
  subscription
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum InvoiceStatus {
  draft
  sent
  paid
}

enum ReferralInviteStatus {
  pending
  used
  rewarded

  @@map("referral_invite_status")
}

enum TherapyOrientation {
  TCC
  PSYCHODYNAMIQUE
  SYSTEMIQUE
  ACT
  AUTRE
}

enum ConsultationCategory {
  standard
  mon_soutien_psy
}

enum AppointmentPaymentMode {
  none
  prepayment
  post_session
}

enum BookingPaymentStatus {
  none
  pending_payment
  paid
  payment_failed
  refunded
}

enum PaymentMode {
  prepaid
  postpaid
  both
}

enum WaitlistUrgency {
  low
  medium
  high
}

enum WaitlistStatus {
  waiting
  contacted
  scheduled
  removed
}

enum VideoRoomStatus {
  waiting
  active
  ended
}

enum SessionStatus {
  draft
  completed
}

enum InvoiceSource {
  manual
  auto
}

enum ExpenseCategory {
  rent
  insurance
  equipment
  it_software
  phone_internet
  training
  supervision
  professional_fees
  transport
  office_supplies
  tests_tools
  bank_fees
  accounting
  cleaning
  other
}

enum ExpensePaymentMethod {
  cash
  check
  card
  transfer
  bank_transfer
  direct_debit
  stripe
  paypal
  other
}

enum RecurringFrequency {
  monthly
  quarterly
  yearly
}

enum AccountingEntryType {
  income
  expense
}

// =============================================================================
// Core Tables
// =============================================================================

model User {
  id                      String    @id @default(uuid())
  email                   String    @unique
  passwordHash            String?   @map("password_hash") // patients only — null for psychologists (Keycloak)
  role                    UserRole  @default(patient)
  avatarUrl               String?   @map("avatar_url")
  locale                  String    @default("fr")
  timezone                String    @default("Europe/Paris")
  lastSignInAt            DateTime? @map("last_sign_in_at")
  pushToken               String?   @map("push_token")
  pushPlatform            String?   @map("push_platform")
  notificationPreferences Json?     @map("notification_preferences")
  createdAt               DateTime  @default(now()) @map("created_at")

  // Relations
  psychologist      Psychologist?
  patient           Patient?           @relation("UserPatient")
  auditLogs         AuditLog[]
  notifications     Notification[]
  courseEnrollments CourseEnrollment[]
  sentMessages      Message[]          @relation("MessageSender")

  @@map("users")
}

model Psychologist {
  id                     String   @id @default(uuid())
  userId                 String   @unique @map("user_id")
  name                   String
  slug                   String   @unique
  specialization         String?
  bio                    String?
  phone                  String?
  address                String?
  adeliNumber            String?  @map("adeli_number")
  isOnboarded            Boolean  @default(false) @map("is_onboarded")
  defaultSessionDuration Int      @default(50) @map("default_session_duration")
  defaultSessionRate     Decimal? @map("default_session_rate") @db.Decimal(10, 2)
  createdAt              DateTime @default(now()) @map("created_at")

  // Relations
  user                     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription             Subscription?
  patients                 Patient[]
  sessions                 Session[]
  appointments             Appointment[]
  courses                  Course[]
  payments                 Payment[]
  invoices                 Invoice[]
  onboardingProgress       OnboardingProgress?
  patientInvitations       PatientInvitation[]
  aiUsages                 AiUsage[]
  conversations            Conversation[]
  marketingContents        MarketingContent[]
  assessments              Assessment[]
  noteTemplates            NoteTemplate[]
  networkProfile           PsyNetworkProfile?
  referralsSent            Referral[]              @relation("ReferralFrom")
  referralsReceived        Referral[]              @relation("ReferralTo")
  networkGroups            NetworkGroup[]          @relation("NetworkGroupOwner")
  groupMemberships         NetworkGroupMember[]    @relation("NetworkGroupMembership")
  supervisionGroups        SupervisionGroup[]      @relation("SupervisionGroupOwner")
  supervisionMemberships   SupervisionMember[]     @relation("SupervisionMembership")
  caseStudies              CaseStudy[]             @relation("CaseStudyPresenter")
  availability             Availability[]
  referralInvitesSent      ReferralInvite[]        @relation("InviteFrom")
  referralInviteReceived   ReferralInvite?         @relation("InviteTo")
  allowOnlinePayment       Boolean                 @default(false) @map("allow_online_payment")
  stripeAccountId          String?                 @unique @map("stripe_account_id")
  stripeOnboardingComplete Boolean                 @default(false) @map("stripe_onboarding_complete")
  paymentMode              PaymentMode             @default(both) @map("payment_mode")
  cancellationDelay        Int                     @default(24) @map("cancellation_delay")
  autoRefund               Boolean                 @default(true) @map("auto_refund")
  autoInvoice              Boolean                 @default(true) @map("auto_invoice")
  autoInvoiceEmail         Boolean                 @default(true) @map("auto_invoice_email")
  reminderDelay            Int                     @default(24) @map("reminder_delay")
  reminderSmsEnabled       Boolean                 @default(false) @map("reminder_sms_enabled")
  reminderEmailEnabled     Boolean                 @default(true) @map("reminder_email_enabled")
  reminderTemplate         String?                 @map("reminder_template")
  consultationTypes        ConsultationType[]
  monSoutienPsyTrackings   MonSoutienPsyTracking[]
  waitlistEntries          WaitlistEntry[]
  videoRooms               VideoRoom[]
  expenses                 Expense[]
  recurringExpenses        RecurringExpense[]
  accountingEntries        AccountingEntry[]
  fecSequences             FecSequence[]

  @@map("psychologists")
}

model Availability {
  id             String  @id @default(uuid())
  psychologistId String  @map("psychologist_id")
  dayOfWeek      Int // 0=Lundi, 1=Mardi, ..., 6=Dimanche
  startTime      String // "09:00"
  endTime        String // "17:00"
  isActive       Boolean @default(true) @map("is_active")

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([psychologistId], name: "idx_availability_psy")
  @@map("availability")
}

model ConsultationType {
  id             String               @id @default(uuid())
  psychologistId String               @map("psychologist_id")
  name           String
  duration       Int
  rate           Decimal              @db.Decimal(10, 2)
  color          String               @default("#3D52A0")
  category       ConsultationCategory @default(standard)
  isPublic       Boolean              @default(true) @map("is_public")
  isActive       Boolean              @default(true) @map("is_active")
  sortOrder      Int                  @default(0) @map("sort_order")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  psychologist    Psychologist    @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  waitlistEntries WaitlistEntry[]

  @@index([psychologistId], name: "idx_consultation_types_psy")
  @@map("consultation_types")
}

model MonSoutienPsyTracking {
  id             String    @id @default(uuid())
  psychologistId String    @map("psychologist_id")
  patientId      String    @map("patient_id")
  year           Int
  sessionsUsed   Int       @default(0) @map("sessions_used")
  maxSessions    Int       @default(12) @map("max_sessions")
  firstSessionAt DateTime? @map("first_session_at")
  lastSessionAt  DateTime? @map("last_session_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([psychologistId, patientId, year])
  @@index([psychologistId, year], name: "idx_msp_psy_year")
  @@map("mon_soutien_psy_tracking")
}

model WaitlistEntry {
  id                 String          @id @default(uuid())
  psychologistId     String          @map("psychologist_id")
  patientName        String          @map("patient_name")
  patientEmail       String          @map("patient_email")
  patientPhone       String?         @map("patient_phone")
  consultationTypeId String?         @map("consultation_type_id")
  urgency            WaitlistUrgency @default(low)
  preferredSlots     Json?           @map("preferred_slots")
  note               String?
  status             WaitlistStatus  @default(waiting)
  contactedAt        DateTime?       @map("contacted_at")
  createdAt          DateTime        @default(now()) @map("created_at")

  psychologist     Psychologist      @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  consultationType ConsultationType? @relation(fields: [consultationTypeId], references: [id])

  @@index([psychologistId, status], name: "idx_waitlist_psy_status")
  @@map("waitlist_entries")
}

model Subscription {
  id                   String             @id @default(uuid())
  psychologistId       String             @unique @map("psychologist_id")
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  plan                 SubscriptionPlan   @default(free)
  status               SubscriptionStatus @default(trialing)
  trialEndsAt          DateTime?          @map("trial_ends_at")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([stripeSubscriptionId], name: "idx_subscriptions_stripe")
  @@map("subscriptions")
}

// =============================================================================
// Patient Tables
// =============================================================================

model Patient {
  id             String        @id @default(uuid())
  psychologistId String        @map("psychologist_id")
  userId         String?       @unique @map("user_id")
  name           String
  email          String?
  phone          String?
  birthDate      DateTime?     @map("birth_date") @db.Date
  notes          String? // ENCRYPTED — AES-256-GCM
  status         PatientStatus @default(active)
  source         String?
  createdAt      DateTime      @default(now()) @map("created_at")

  // Relations
  psychologist           Psychologist            @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  user                   User?                   @relation("UserPatient", fields: [userId], references: [id], onDelete: SetNull)
  sessions               Session[]
  appointments           Appointment[]
  moodTrackings          MoodTracking[]
  exercises              Exercise[]
  journalEntries         JournalEntry[]
  conversations          Conversation[]
  gdprConsents           GdprConsent[]
  invitations            PatientInvitation[]
  payments               Payment[]
  invoices               Invoice[]
  assessments            Assessment[]
  monSoutienPsyTrackings MonSoutienPsyTracking[]
  appointmentParticipations AppointmentParticipant[]

  @@index([psychologistId], name: "idx_patients_psychologist")
  @@map("patients")
}

model Session {
  id             String               @id @default(uuid())
  patientId      String               @map("patient_id")
  psychologistId String               @map("psychologist_id")
  date           DateTime
  duration       Int // minutes
  type           SessionType          @default(individual)
  notes          String? // ENCRYPTED — AES-256-GCM
  summaryAi      String?              @map("summary_ai") // ENCRYPTED si contient données patients
  tags           String[]
  rate           Decimal?             @db.Decimal(10, 2)
  paymentStatus  SessionPaymentStatus @default(pending) @map("payment_status")
  participantIds String[]             @default([]) @map("participant_ids")
  orientation    TherapyOrientation?
  templateId     String?              @map("template_id")
  aiMetadata     Json?                @map("ai_metadata")
  status         SessionStatus        @default(draft)
  createdAt      DateTime             @default(now()) @map("created_at")

  // Relations
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  appointment  Appointment?
  invoices     Invoice[]

  @@index([patientId], name: "idx_sessions_patient")
  @@index([psychologistId, date(sort: Desc)], name: "idx_sessions_psy_date")
  @@map("sessions")
}

model NoteTemplate {
  id             String             @id @default(uuid())
  psychologistId String?            @map("psychologist_id") // null = template système
  orientation    TherapyOrientation
  name           String
  description    String?
  sections       Json // Array<{ id: string; title: string; placeholder: string; required: boolean }>
  isSystem       Boolean            @default(false) @map("is_system")
  isActive       Boolean            @default(true) @map("is_active")
  createdAt      DateTime           @default(now()) @map("created_at")

  psychologist Psychologist? @relation(fields: [psychologistId], references: [id], onDelete: SetNull)

  @@index([psychologistId], name: "idx_note_templates_psy")
  @@map("note_templates")
}

// =============================================================================
// Network / Réseau Pro
// =============================================================================

enum ReferralStatus {
  pending
  accepted
  declined
  completed
}

enum GroupType {
  supervision
  intervision
  formation
  autre
}

model PsyNetworkProfile {
  id                   String   @id @default(uuid())
  psychologistId       String   @unique @map("psychologist_id")
  isVisible            Boolean  @default(true) @map("is_visible") // visible dans l'annuaire
  city                 String?
  department           String? // ex: "54", "75"
  approaches           String[] // ex: ["TCC", "ACT", "PSYCHODYNAMIQUE"]
  specialties          String[] // ex: ["anxiété", "dépression", "trauma"]
  languages            String[] @default(["fr"])
  acceptsReferrals     Boolean  @default(true) @map("accepts_referrals")
  acceptsMonSoutienPsy Boolean  @default(false) @map("accepts_mon_soutien_psy")
  offersVisio          Boolean  @default(false) @map("offers_visio") // Séances en visioconférence
  bio                  String? // bio réseau (différente de la bio cabinet)
  avatarUrl            String?  @map("avatar_url")
  websiteUrl           String?  @map("website_url")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@map("psy_network_profiles")
}

model Referral {
  id              String         @id @default(uuid())
  fromPsyId       String         @map("from_psy_id")
  toPsyId         String         @map("to_psy_id")
  patientInitials String?        @map("patient_initials") // jamais nom complet
  message         String? // ENCRYPTED AES-256-GCM
  reason          String? // motif d'adressage
  status          ReferralStatus @default(pending)
  respondedAt     DateTime?      @map("responded_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  fromPsy Psychologist @relation("ReferralFrom", fields: [fromPsyId], references: [id], onDelete: Cascade)
  toPsy   Psychologist @relation("ReferralTo", fields: [toPsyId], references: [id], onDelete: Cascade)

  @@index([fromPsyId, createdAt(sort: Desc)])
  @@index([toPsyId, status])
  @@map("referrals")
}

model NetworkGroup {
  id          String    @id @default(uuid())
  ownerId     String    @map("owner_id")
  type        GroupType
  name        String
  description String?
  city        String?
  isPrivate   Boolean   @default(false) @map("is_private")
  maxMembers  Int       @default(20) @map("max_members")
  createdAt   DateTime  @default(now()) @map("created_at")

  owner   Psychologist         @relation("NetworkGroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members NetworkGroupMember[]

  @@index([ownerId], name: "idx_network_groups_owner")
  @@map("network_groups")
}

model NetworkGroupMember {
  id       String   @id @default(uuid())
  groupId  String   @map("group_id")
  psyId    String   @map("psy_id")
  role     String   @default("member") // "owner" | "member"
  joinedAt DateTime @default(now()) @map("joined_at")

  group NetworkGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  psy   Psychologist @relation("NetworkGroupMembership", fields: [psyId], references: [id], onDelete: Cascade)

  @@unique([groupId, psyId])
  @@map("network_group_members")
}

model Appointment {
  id                   String               @id @default(uuid())
  psychologistId       String               @map("psychologist_id")
  patientId            String               @map("patient_id")
  sessionId            String?              @unique @map("session_id")
  scheduledAt          DateTime             @map("scheduled_at")
  duration             Int // minutes
  status               AppointmentStatus    @default(scheduled)
  reminderSentAt       DateTime?            @map("reminder_sent_at")
  smsReminderSentAt    DateTime?            @map("sms_reminder_sent_at")
  reason               String? // motif de consultation
  source               String               @default("internal") // "internal" | "public"
  cancelToken          String?              @unique @map("cancel_token")
  consultationTypeId   String?              @map("consultation_type_id")
  paymentIntentId      String?              @map("payment_intent_id")
  paymentAmount        Decimal?             @map("payment_amount") @db.Decimal(10, 2)
  paymentMode          AppointmentPaymentMode @default(none) @map("payment_mode")
  paidOnline           Boolean              @default(false) @map("paid_online")
  bookingPaymentStatus BookingPaymentStatus @default(none) @map("booking_payment_status")
  isOnline             Boolean              @default(false) @map("is_online")
  videoJoinToken       String?              @unique @map("video_join_token")
  videoLinkSentAt      DateTime?            @map("video_link_sent_at")
  createdAt            DateTime             @default(now()) @map("created_at")

  psychologist     Psychologist      @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  patient          Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  session          Session?          @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  consultationType ConsultationType? @relation(fields: [consultationTypeId], references: [id], onDelete: SetNull)
  payments         Payment[]
  videoRoom        VideoRoom?
  participants     AppointmentParticipant[]

  @@index([psychologistId, scheduledAt], name: "idx_appointments_psy_date")
  @@index([patientId], name: "idx_appointments_patient")
  @@index([consultationTypeId], name: "idx_appointments_consultation_type")
  @@map("appointments")
}

model VideoRoom {
  id              String          @id @default(uuid())
  appointmentId   String          @unique @map("appointment_id")
  appointment     Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  psychologistId  String          @map("psychologist_id")
  psychologist    Psychologist    @relation(fields: [psychologistId], references: [id])
  roomName        String          @unique @map("room_name")
  status          VideoRoomStatus @default(waiting)
  psyJoinedAt     DateTime?       @map("psy_joined_at")
  patientJoinedAt DateTime?       @map("patient_joined_at")
  endedAt         DateTime?       @map("ended_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([psychologistId, status])
  @@map("video_rooms")
}

model AppointmentParticipant {
  id              String    @id @default(uuid())
  appointmentId   String    @map("appointment_id")
  patientId       String    @map("patient_id")
  videoJoinToken  String?   @unique @map("video_join_token")
  videoLinkSentAt DateTime? @map("video_link_sent_at")
  joinedAt        DateTime? @map("joined_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, patientId])
  @@index([patientId])
  @@index([videoJoinToken])
  @@map("appointment_participants")
}

// =============================================================================
// Patient Portal Tables
// =============================================================================

model MoodTracking {
  id        String   @id @default(uuid())
  patientId String   @map("patient_id")
  mood      Int // 1-10
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt(sort: Desc)], name: "idx_mood_patient_date")
  @@map("mood_tracking")
}

model Exercise {
  id              String         @id @default(uuid())
  patientId       String         @map("patient_id")
  title           String
  description     String
  status          ExerciseStatus @default(assigned)
  createdByAi     Boolean        @default(false) @map("created_by_ai")
  dueDate         DateTime?      @map("due_date") @db.Date
  completedAt     DateTime?      @map("completed_at")
  patientFeedback String?        @map("patient_feedback")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId], name: "idx_exercises_patient")
  @@map("exercises")
}

model JournalEntry {
  id        String   @id @default(uuid())
  patientId String   @map("patient_id")
  content   String // ENCRYPTED — AES-256-GCM
  mood      Int?
  tags      String[]
  isPrivate Boolean  @default(false) @map("is_private")
  createdAt DateTime @default(now()) @map("created_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId], name: "idx_journal_entries_patient")
  @@map("journal_entries")
}

// =============================================================================
// Messaging Tables
// =============================================================================

model Conversation {
  id             String   @id @default(uuid())
  psychologistId String   @map("psychologist_id")
  patientId      String   @map("patient_id")
  createdAt      DateTime @default(now()) @map("created_at")

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([psychologistId, patientId])
  @@map("conversations")
}

model Message {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  senderId       String?   @map("sender_id")
  content        String // ENCRYPTED — AES-256-GCM
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId, readAt], name: "idx_messages_conv_read")
  @@map("messages")
}

// =============================================================================
// Formations Tables
// =============================================================================

model Course {
  id             String   @id @default(uuid())
  psychologistId String   @map("psychologist_id")
  title          String
  description    String
  price          Decimal  @db.Decimal(10, 2)
  isPublished    Boolean  @default(false) @map("is_published")
  createdAt      DateTime @default(now()) @map("created_at")

  psychologist Psychologist       @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  modules      CourseModule[]
  enrollments  CourseEnrollment[]

  @@index([psychologistId], name: "idx_courses_psy")
  @@map("courses")
}

model CourseModule {
  id       String  @id @default(uuid())
  courseId String  @map("course_id")
  title    String
  videoUrl String? @map("video_url")
  content  String?
  order    Int     @default(0)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId], name: "idx_course_modules_course")
  @@map("course_modules")
}

model CourseEnrollment {
  id         String   @id @default(uuid())
  courseId   String   @map("course_id")
  userId     String?  @map("user_id")
  paymentId  String?  @map("payment_id")
  progress   Json     @default("{}")
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([courseId, userId])
  @@index([userId], name: "idx_course_enrollments_user")
  @@map("course_enrollments")
}

// =============================================================================
// Billing Tables
// =============================================================================

model Payment {
  id                    String        @id @default(uuid())
  psychologistId        String        @map("psychologist_id")
  patientId             String?       @map("patient_id")
  type                  PaymentType
  amount                Decimal       @db.Decimal(10, 2)
  status                PaymentStatus @default(pending)
  stripePaymentIntentId   String?       @map("stripe_payment_intent_id")
  stripeCheckoutSessionId String?       @unique @map("stripe_checkout_session_id")
  invoiceUrl              String?       @map("invoice_url")
  appointmentId           String?       @db.Uuid @map("appointment_id")
  createdAt               DateTime      @default(now()) @map("created_at")

  psychologist      Psychologist      @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  patient           Patient?          @relation(fields: [patientId], references: [id], onDelete: SetNull)
  appointment       Appointment?      @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  invoices          Invoice[]
  accountingEntries AccountingEntry[]

  @@index([appointmentId])
  @@index([patientId], name: "idx_payments_patient")
  @@index([psychologistId, status], name: "idx_payments_psy_status")
  @@map("payments")
}

model Invoice {
  id             String        @id @default(uuid())
  psychologistId String        @map("psychologist_id")
  patientId      String?       @map("patient_id")
  invoiceNumber  String        @unique @map("invoice_number")
  amountTtc      Decimal       @map("amount_ttc") @db.Decimal(10, 2)
  status         InvoiceStatus @default(draft)
  issuedAt       DateTime      @map("issued_at") @db.Date
  pdfUrl         String?       @map("pdf_url")
  sessionId      String?       @map("session_id")
  paymentId      String?       @map("payment_id")
  paidAt         DateTime?     @map("paid_at")
  source         InvoiceSource @default(manual)

  psychologist      Psychologist      @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  patient           Patient?          @relation(fields: [patientId], references: [id], onDelete: SetNull)
  session           Session?          @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  payment           Payment?          @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  accountingEntries AccountingEntry[]

  @@index([psychologistId], name: "idx_invoices_psy")
  @@index([patientId], name: "idx_invoices_patient")
  @@index([paymentId], name: "idx_invoices_payment")
  @@index([sessionId], name: "idx_invoices_session")
  @@map("invoices")
}

model StripeEvent {
  id            String   @id @default(uuid())
  stripeEventId String   @unique @map("stripe_event_id")
  type          String
  processedAt   DateTime @default(now()) @map("processed_at")

  @@map("stripe_events")
}

// =============================================================================
// Compliance HDS Tables
// =============================================================================

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  actorType  String   @map("actor_type")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  ipAddress  String?  @map("ip_address")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt(sort: Desc)], name: "idx_audit_entity")
  @@map("audit_logs")
}

model GdprConsent {
  id          String    @id @default(uuid())
  patientId   String    @map("patient_id")
  type        String
  version     String
  consentedAt DateTime  @default(now()) @map("consented_at")
  withdrawnAt DateTime? @map("withdrawn_at")
  ipAddress   String?   @map("ip_address")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId], name: "idx_gdpr_consents_patient")
  @@map("gdpr_consents")
}

// ============ Outcome Tracking ============

enum AssessmentType {
  PHQ9
  GAD7
  CORE_OM
}

enum AssessmentStatus {
  pending
  completed
}

model AssessmentTemplate {
  id            String         @id @default(uuid())
  type          AssessmentType
  name          String
  description   String?
  questions     Json // Array<{ id: string; text: string; minValue: number; maxValue: number; labels: string[] }>
  scoringRanges Json // Array<{ min: number; max: number; label: string; severity: string }>
  maxScore      Int            @map("max_score")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")

  assessments Assessment[]

  @@map("assessment_templates")
}

model Assessment {
  id             String           @id @default(uuid())
  templateId     String           @map("template_id")
  patientId      String           @map("patient_id")
  psychologistId String           @map("psychologist_id")
  answers        String? // ENCRYPTED — AES-256-GCM (JSON stringifié avant chiffrement)
  score          Int?
  severity       String?
  status         AssessmentStatus @default(pending)
  completedAt    DateTime?        @map("completed_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  template     AssessmentTemplate @relation(fields: [templateId], references: [id])
  patient      Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  psychologist Psychologist       @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt(sort: Desc)], name: "idx_assessments_patient_date")
  @@index([psychologistId], name: "idx_assessments_psy")
  @@map("assessments")
}

// =============================================================================
// System Tables
// =============================================================================

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt], name: "idx_notifications_user_read")
  @@map("notifications")
}

model OnboardingProgress {
  id             String    @id @default(uuid())
  psychologistId String    @unique @map("psychologist_id")
  stepsCompleted String[]  @map("steps_completed")
  completedAt    DateTime? @map("completed_at")

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@map("onboarding_progress")
}

model PatientInvitation {
  id             String           @id @default(uuid())
  psychologistId String           @map("psychologist_id")
  patientId      String           @map("patient_id")
  email          String
  token          String           @unique
  status         InvitationStatus @default(pending)
  expiresAt      DateTime         @map("expires_at")

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([psychologistId], name: "idx_patient_invitations_psy")
  @@index([patientId], name: "idx_patient_invitations_patient")
  @@map("patient_invitations")
}

model AiUsage {
  id             String   @id @default(uuid())
  psychologistId String   @map("psychologist_id")
  feature        String
  tokensUsed     Int      @map("tokens_used")
  model          String
  costUsd        Decimal  @map("cost_usd") @db.Decimal(10, 6)
  createdAt      DateTime @default(now()) @map("created_at")

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([psychologistId, createdAt(sort: Desc)], name: "idx_ai_usage_psy_date")
  @@map("ai_usage")
}

model MarketingContent {
  id             String   @id @default(uuid())
  psychologistId String   @map("psychologist_id")
  type           String // linkedin | newsletter | blog
  theme          String
  tone           String // professional | warm | educational
  content        String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([psychologistId], name: "idx_marketing_contents_psy")
  @@map("marketing_contents")
}

model Lead {
  id        String   @id @default(uuid())
  email     String   @unique
  source    String   @default("landing_beta")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("leads")
}

// ─── Supervision / Intervision ──────────────────────────────────────────────

enum SupervisionGroupType {
  supervision
  intervision

  @@map("supervision_group_type")
}

enum SupervisionSessionStatus {
  planned
  completed
  cancelled

  @@map("supervision_session_status")
}

model SupervisionGroup {
  id          String               @id @default(uuid())
  ownerId     String               @map("owner_id")
  type        SupervisionGroupType
  name        String
  description String?
  isPrivate   Boolean              @default(false) @map("is_private")
  maxMembers  Int                  @default(12) @map("max_members")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  owner    Psychologist         @relation("SupervisionGroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  SupervisionMember[]
  sessions SupervisionSession[]

  @@map("supervision_groups")
}

model SupervisionMember {
  id       String   @id @default(uuid())
  groupId  String   @map("group_id")
  psyId    String   @map("psy_id")
  role     String   @default("member") // "owner" | "member"
  joinedAt DateTime @default(now()) @map("joined_at")

  group SupervisionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  psy   Psychologist     @relation("SupervisionMembership", fields: [psyId], references: [id], onDelete: Cascade)

  @@unique([groupId, psyId])
  @@map("supervision_members")
}

model SupervisionSession {
  id          String                   @id @default(uuid())
  groupId     String                   @map("group_id")
  scheduledAt DateTime                 @map("scheduled_at")
  duration    Int                      @default(90) // minutes
  location    String? // visio URL ou adresse
  status      SupervisionSessionStatus @default(planned)
  notes       String?                  @db.Text // ENCRYPTED AES-256-GCM
  createdAt   DateTime                 @default(now()) @map("created_at")

  group       SupervisionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  caseStudies CaseStudy[]

  @@index([groupId, scheduledAt(sort: Desc)])
  @@map("supervision_sessions")
}

model CaseStudy {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  presenterId String   @map("presenter_id")
  // Données anonymisées uniquement — jamais nom/identifiant patient
  initials    String? // ex: "P.M." — optionnel
  ageRange    String?  @map("age_range") // ex: "30-40 ans"
  problematic String   @db.Text
  content     String   @db.Text // ENCRYPTED AES-256-GCM
  createdAt   DateTime @default(now()) @map("created_at")

  session   SupervisionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  presenter Psychologist       @relation("CaseStudyPresenter", fields: [presenterId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([presenterId], name: "idx_case_studies_presenter")
  @@map("case_studies")
}

// =============================================================================
// Accounting Tables
// =============================================================================

model Expense {
  id                 String               @id @default(uuid())
  psychologistId     String               @map("psychologist_id")
  psychologist       Psychologist         @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  date               DateTime             @db.Date
  label              String
  amount             Decimal              @db.Decimal(10, 2)
  amountHt           Decimal?             @map("amount_ht") @db.Decimal(10, 2)
  vatRate            Decimal?             @map("vat_rate") @db.Decimal(4, 2)
  category           ExpenseCategory
  subcategory        String?
  paymentMethod      ExpensePaymentMethod @map("payment_method")
  supplier           String?
  receiptUrl         String?              @map("receipt_url")
  recurringExpenseId String?              @map("recurring_expense_id")
  recurringExpense   RecurringExpense?    @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)
  notes              String?              // ENCRYPTED — AES-256-GCM
  isDeductible       Boolean              @default(true) @map("is_deductible")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  deletedAt          DateTime?            @map("deleted_at")

  accountingEntries AccountingEntry[]

  @@index([psychologistId, date(sort: Desc)], name: "idx_expenses_psy_date")
  @@index([psychologistId, category], name: "idx_expenses_psy_category")
  @@map("expenses")
}

model RecurringExpense {
  id              String               @id @default(uuid())
  psychologistId  String               @map("psychologist_id")
  psychologist    Psychologist         @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  label           String
  amount          Decimal              @db.Decimal(10, 2)
  category        ExpenseCategory
  paymentMethod   ExpensePaymentMethod @map("payment_method")
  supplier        String?
  frequency       RecurringFrequency
  dayOfMonth      Int                  @default(1) @map("day_of_month")
  startDate       DateTime             @db.Date @map("start_date")
  endDate         DateTime?            @db.Date @map("end_date")
  isActive        Boolean              @default(true) @map("is_active")
  lastGeneratedAt DateTime?            @db.Date @map("last_generated_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  expenses Expense[]

  @@index([psychologistId], name: "idx_recurring_psy")
  @@index([isActive, lastGeneratedAt], name: "idx_recurring_active")
  @@map("recurring_expenses")
}

model AccountingEntry {
  id             String              @id @default(uuid())
  psychologistId String              @map("psychologist_id")
  psychologist   Psychologist        @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  date           DateTime            @db.Date
  entryType      AccountingEntryType @map("entry_type")
  label          String
  debit          Decimal             @default(0) @db.Decimal(10, 2)
  credit         Decimal             @default(0) @db.Decimal(10, 2)
  category       String
  paymentMethod  String?             @map("payment_method")
  counterpart    String?
  invoiceId      String?             @map("invoice_id")
  invoice        Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  paymentId      String?             @map("payment_id")
  payment        Payment?            @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  expenseId      String?             @map("expense_id")
  expense        Expense?            @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  accountCode    String?             @map("account_code")
  pieceRef       String?             @map("piece_ref")
  ecritureNum    Int?                @map("ecriture_num")
  fiscalYear     Int                 @map("fiscal_year")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  deletedAt      DateTime?           @map("deleted_at")

  @@index([psychologistId, date(sort: Desc)], name: "idx_accounting_psy_date")
  @@index([psychologistId, entryType, date], name: "idx_accounting_psy_type_date")
  @@index([invoiceId], name: "idx_accounting_invoice")
  @@index([paymentId], name: "idx_accounting_payment")
  @@index([expenseId], name: "idx_accounting_expense")
  @@index([psychologistId, fiscalYear], name: "idx_accounting_psy_year")
  @@map("accounting_entries")
}

model FecSequence {
  id             String       @id @default(uuid())
  psychologistId String       @map("psychologist_id")
  year           Int
  lastNumber     Int          @default(0) @map("last_number")

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@unique([psychologistId, year])
  @@map("fec_sequences")
}

// =============================================================================
// Referral / Parrainage
// =============================================================================

model ReferralInvite {
  id            String               @id @default(uuid())
  code          String               @unique
  referrerId    String               @map("referrer_id")
  referredId    String?              @unique @map("referred_id")
  status        ReferralInviteStatus @default(pending)
  rewardGivenAt DateTime?            @map("reward_given_at")
  createdAt     DateTime             @default(now()) @map("created_at")

  referrer Psychologist  @relation("InviteFrom", fields: [referrerId], references: [id], onDelete: Cascade)
  referred Psychologist? @relation("InviteTo", fields: [referredId], references: [id], onDelete: SetNull)

  @@index([referrerId])
  @@map("referral_invites")
}
