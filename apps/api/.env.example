SENTRY_DSN=https://xxx@yyy.ingest.de.sentry.io/zzz

# Vérification ADELI/RPPS — API FHIR Annuaire Santé (ANS)
# Clé gratuite via https://portal.api.esante.gouv.fr (app abonnée à "API Annuaire Santé en libre accès")
# Header envoyé : ESANTE-API-KEY. Si absente → validation du format seul (9/11 chiffres), non bloquant.
ESANTE_API_KEY=
ESANTE_API_URL=https://gateway.api.esante.gouv.fr/fhir/v2/Practitioner
# Mettre à "false" pour ne pas exiger la profession « psychologue » (par défaut true)
RPPS_REQUIRE_PSYCHOLOGIST=true

# Pro Santé Connect (e-CPS) — vérification d'identité FORTE des psychologues.
# Nécessite l'enregistrement d'un client OIDC auprès de l'ANS (bac à sable puis
# prod) : https://industriels.esante.gouv.fr → demande d'habilitation PSC.
# Tant que PSC_ENABLED ≠ true et que client_id/secret sont vides → désactivé
# (le bouton "Vérifier avec Pro Santé Connect" est masqué côté front).
PSC_ENABLED=false
PSC_ENV=sandbox                       # sandbox | production
PSC_CLIENT_ID=
PSC_CLIENT_SECRET=
# redirect_uri à déclarer à l'ANS (doit pointer vers cette API) :
PSC_REDIRECT_URI=https://api.psylib.eu/api/v1/auth/psc/callback
# Optionnel : surcharge des endpoints (sinon défauts sandbox/prod intégrés)
# PSC_AUTHORIZE_URL=
# PSC_TOKEN_URL=
# PSC_USERINFO_URL=
