SENTRY_DSN=https://xxx@yyy.ingest.de.sentry.io/zzz

# Vérification ADELI/RPPS — API FHIR Annuaire Santé (ANS)
# Clé gratuite via https://portal.api.esante.gouv.fr (app abonnée à "API Annuaire Santé en libre accès")
# Header envoyé : ESANTE-API-KEY. Si absente → validation du format seul (9/11 chiffres), non bloquant.
ESANTE_API_KEY=
ESANTE_API_URL=https://gateway.api.esante.gouv.fr/fhir/v2/Practitioner
# Mettre à "false" pour ne pas exiger la profession « psychologue » (par défaut true)
RPPS_REQUIRE_PSYCHOLOGIST=true
