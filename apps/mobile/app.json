{
  "expo": {
    "name": "PsyLib",
    "slug": "psyscale",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F7FF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fr.psyscale.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "PsyLib utilise Face ID pour sécuriser l'accès à vos données patients."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3D52A0"
      },
      "package": "fr.psyscale.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-auth-session",
        {}
      ]
    ],
    "scheme": "psyscale",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "keycloakUrl": "http://localhost:8080",
      "keycloakRealm": "psyscale",
      "keycloakClientId": "psyscale-app",
      "apiBaseUrl": "http://localhost:4000",
      "eas": {
        "projectId": "psyscale-mobile"
      }
    }
  }
}
