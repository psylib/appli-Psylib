# Exclude big local files from Vercel upload
tmp/
/BOOKING/
/Nouveau dossier/
docker/
apps/mobile/
.playwright-mcp/
playwright-report/
apps/web/playwright-report/
*.png
*.jpg
*.jpeg
*.mp4
# Ré-inclure les icônes PWA servies statiquement (sinon 404 en prod)
!apps/web/public/icon-192.png
!apps/web/public/icon-512.png
# Marque PsyLib (P + feuilles) : inline (sidebar/nav/login) + favicon/apple-icon (convention Next)
!apps/web/public/logo-mark.png
!apps/web/src/app/icon.png
!apps/web/src/app/apple-icon.png
# Cartes autoposter n8n (servies à psylib.eu/cards/ ; le conteneur n8n AZNetwork ne peut pas joindre n8n.psylib.eu en hairpin)
!apps/web/public/cards/*.png
# Versions animées (MP4) des cartes — autoposter vidéo LinkedIn/Facebook du lundi
!apps/web/public/cards/*.mp4
node_modules/
.turbo/
.next/
.git/
coverage/
test-results/
