# PsyScale API — Variables production OVH
# Copier en .env et remplir les valeurs réelles
# NE JAMAIS committer le .env

# ── Docker image ────────────────────────────────────────────────────────────
GITHUB_REPO_OWNER=ton-github-user    # ex: tonyr (GitHub username, pas repo path)
IMAGE_TAG=latest

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=psyscale
POSTGRES_USER=psyscale
POSTGRES_PASSWORD=CHANGE_ME_FORT_MOT_DE_PASSE_32_CHARS

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_24_CHARS

# ── NestJS / Prisma ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://psyscale:CHANGE_ME_FORT_MOT_DE_PASSE_32_CHARS@postgres:5432/psyscale
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD_24_CHARS@redis:6379
NODE_ENV=production
PORT=4000

# ── JWT ──────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 64
JWT_SECRET=CHANGE_ME_JWT_SECRET_128_CHARS_HEX
PATIENT_JWT_SECRET=CHANGE_ME_PATIENT_JWT_SECRET_128_CHARS_HEX

# ── Chiffrement AES-256-GCM (données HDS) ────────────────────────────────────
# Générer avec : openssl rand -hex 32   (64 chars hex = 32 bytes)
ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX

# ── Keycloak (OVH HDS) ───────────────────────────────────────────────────────
KEYCLOAK_URL=https://auth.psylib.eu
KEYCLOAK_REALM=psyscale
KEYCLOAK_CLIENT_ID=psyscale-app
KEYCLOAK_CLIENT_SECRET=CHANGE_ME

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_ID_STARTER=price_CHANGE_ME
STRIPE_PRICE_ID_PRO=price_CHANGE_ME
STRIPE_PRICE_ID_CLINIC=price_CHANGE_ME
STRIPE_REFERRAL_COUPON_ID=REFERRAL_1MONTH_FREE

# ── IA ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Resend (emails transactionnels) ──────────────────────────────────────────
RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM=PsyLib <noreply@psylib.eu>

# ── SMS (OVH — optionnel, si vide le service skip) ──────────────────────────
OVH_SMS_APP_KEY=
OVH_SMS_APP_SECRET=
OVH_SMS_CONSUMER_KEY=
OVH_SMS_SERVICE_NAME=
OVH_SMS_SENDER=PsyLib

# ── Clé rotation chiffrement (optionnel, pour migration) ─────────────────────
# ENCRYPTION_KEY_V0=ancienne_cle_hex_64_chars

# ── Monitoring ───────────────────────────────────────────────────────────────
INTERNAL_HEALTH_KEY=CHANGE_ME_RANDOM_STRING

# ── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://psylib.eu
