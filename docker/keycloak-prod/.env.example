# PsyScale — Keycloak Production Secrets
# Copier en .env et remplir les valeurs
# NE JAMAIS COMMITTER .env

# --- Base de données & admin ---
KC_DB_PASSWORD=change_me_strong_password_32chars
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=change_me_strong_admin_password

# --- Secrets injectés dans le realm à l'import (placeholders ${...} du realm JSON) ---
# IMPORTANT : ne sont consommés qu'au PREMIER import (le realm `psyscale` existant
# en prod n'est pas ré-importé au restart). Générer des secrets forts :
#   openssl rand -base64 36
KC_CLIENT_SECRET_APP=change_me_oidc_client_secret_app
KC_CLIENT_SECRET_ADMIN=change_me_oidc_client_secret_admin
# Clé API Resend utilisée par Keycloak pour le SMTP (envoi des emails realm)
KC_SMTP_PASSWORD=change_me_resend_api_key
